---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Voice & Dialect Coach, London">
  <section class="hero">
    <div class="hero__inner container">
      <div class="hero__text">
        <p class="eyebrow fade-in">Voice & Dialect Coach · London</p>
        <h1 class="fade-in-delay">Danièle<br />Lydon</h1>
        <div class="gold-rule fade-in-delay"></div>
        <p class="hero__sub fade-in-delay-2">Working at the highest levels of film, television and theatre — and with individuals and organisations who want to find their voice.</p>
        <div class="hero__credits fade-in-delay-2">
          <span>House of the Dragon</span>
          <span>Harry Potter & The Cursed Child</span>
          <span>Rogue One: A Star Wars Story</span>
        </div>
        <a href="/what-i-do" class="btn fade-in-delay-2">Discover my work</a>
      </div>
      <div class="hero__image fade-in-delay">
        <img src="https://static.wixstatic.com/media/74aaf2_09a6ce0facd64b6497227a789928d708~mv2.jpg/v1/fill/w_800,h_900,al_c,q_85/Daniel-Lydon-768x512-2.jpg" alt="Danièle Lydon" width="500" height="580"/>
      </div>
    </div>
  </section>
  <section class="section section--dark">
    <div class="container--narrow" style="text-align:center">
      <p class="eyebrow" style="color:var(--gold)">The work</p>
      <h2 style="font-size:clamp(1.8rem,3.5vw,2.8rem);margin-top:1rem;color:var(--warm-white);line-height:1.4;">"Sensitive, skilful and perceptive — my casts always trusted her."</h2>
      <p style="color:var(--mid-grey);font-family:var(--font-ui);font-size:0.8rem;letter-spacing:0.1em;text-transform:uppercase;margin-top:1.5rem;">Edward Hall, Director</p>
    </div>
  </section>
  <section class="section">
    <div class="container">
      <div class="two-col">
        <div class="two-col__item">
          <p class="eyebrow">For Actors</p>
          <div class="gold-rule"></div>
          <h2>Accent &<br />Dialect Work</h2>
          <p>Working with actors in film, theatre and television to find the skills required for a particular accent or vocal quality.</p>
          <a href="/what-i-do" class="link-arrow">Learn more →</a>
        </div>
        <div class="two-col__item">
          <p class="eyebrow">For Business</p>
          <div class="gold-rule"></div>
          <h2>Voice &<br />Communication</h2>
          <p>Working with individuals and organisations to develop confident, authentic communication. Presentation skills, vocal presence, and the tools of great speaking.</p>
          <a href="/what-i-do" class="link-arrow">Learn more →</a>
        </div>
      </div>
    </div>
  </section>
  <section class="section section--grey">
    <div class="container">
      <p class="eyebrow">Selected credits</p>
      <div class="gold-rule"></div>
      <h2 style="font-size:clamp(1.8rem,3vw,2.5rem);margin-bottom:3rem;">A career at the<br />heart of the industry</h2>
      <div class="credits-grid">
        <div class="credit"><span class="credit__type">Television</span><span class="credit__title">House of the Dragon</span><span class="credit__role">Lead Voice Coach</span></div>
        <div class="credit"><span class="credit__type">West End</span><span class="credit__title">Harry Potter & The Cursed Child</span><span class="credit__role">Resident Dialect Coach</span></div>
        <div class="credit"><span class="credit__type">Film</span><span class="credit__title">Rogue One: A Star Wars Story</span><span class="credit__role">Language Creation & Dialect</span></div>
        <div class="credit"><span class="credit__type">Film</span><span class="credit__title">Death on the Nile</span><span class="credit__role">Dialect Coach · Dir. Kenneth Branagh</span></div>
        <div class="credit"><span class="credit__type">West End</span><span class="credit__title">Billy Elliott</span><span class="credit__role">Dialect Residency · Dir. Stephen Daldry</span></div>
        <div class="credit"><span class="credit__type">West End</span><span class="credit__title">School of Rock</span><span class="credit__role">Dialect Residency · Andrew Lloyd Webber</span></div>
      </div>
      <div style="margin-top:3rem;text-align:center;"><a href="/work" class="btn btn--outline">Full credits</a></div>
    </div>
  </section>
  <section class="section">
    <div class="container--narrow" style="text-align:center">
      <p class="eyebrow">From the work</p>
      <div class="gold-rule" style="margin:1.5rem auto;"></div>
      <blockquote class="pull-quote">"Not only was Danièle's coaching spot on, but I was also helped on many occasions by her positive encouragement."</blockquote>
      <p class="attribution">Ken Watanabe · The King & I, West End</p>
      <a href="/testimonials" class="link-arrow" style="display:inline-block;margin-top:2rem;">Read all testimonials →</a>
    </div>
  </section>
</Layout>
<style>
  .hero{min-height:calc(100vh - 70px);display:flex;align-items:center;padding:5rem 0}
  .hero__inner{display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:center}
  .hero__text h1{font-size:clamp(3.5rem,6vw,5.5rem);line-height:1.05;margin:1rem 0}
  .hero__sub{font-size:1.15rem;color:#444;max-width:480px;margin:1.5rem 0}
  .hero__credits{display:flex;flex-direction:column;gap:0.4rem;margin:2rem 0;padding-left:1rem;border-left:2px solid var(--gold)}
  .hero__credits span{font-family:var(--font-ui);font-size:0.78rem;font-weight:500;letter-spacing:0.06em;color:var(--mid-grey);text-transform:uppercase}
  .hero__image{position:relative}
  .hero__image::before{content:'';position:absolute;top:-20px;right:-20px;bottom:20px;left:20px;border:1px solid var(--light-grey);z-index:-1}
  .hero__image img{width:100%;height:580px;object-fit:cover;display:block;filter:grayscale(15%)}
  .btn{display:inline-block;font-family:var(--font-ui);font-size:0.75rem;font-weight:500;letter-spacing:0.15em;text-transform:uppercase;padding:0.9rem 2.5rem;background:var(--charcoal);color:var(--warm-white);text-decoration:none;transition:background 0.25s}
  .btn:hover{background:var(--gold)}
  .btn--outline{background:transparent;color:var(--charcoal);border:1.5px solid var(--charcoal)}
  .btn--outline:hover{background:var(--charcoal);color:var(--warm-white)}
  .link-arrow{font-family:var(--font-ui);font-size:0.8rem;font-weight:500;letter-spacing:0.08em;color:var(--gold);text-decoration:none}
  .two-col{display:grid;grid-template-columns:1fr 1fr;gap:5rem}
  .two-col__item h2{font-size:2rem;margin-bottom:1.2rem}
  .two-col__item p{color:#555;margin-bottom:1.5rem;font-size:1.05rem}
  .credits-grid{display:grid;grid-template-columns:repeat(3,1fr);border-top:1px solid var(--light-grey)}
  .credit{padding:2rem 2rem 2rem 0;border-bottom:1px solid var(--light-grey);display:flex;flex-direction:column;gap:0.4rem}
  .credit__type{font-family:var(--font-ui);font-size:0.65rem;font-weight:500;letter-spacing:0.15em;text-transform:uppercase;color:var(--gold)}
  .credit__title{font-family:var(--font-display);font-size:1.1rem;font-weight:600}
  .credit__role{font-family:var(--font-ui);font-size:0.78rem;color:var(--mid-grey)}
  .pull-quote{font-family:var(--font-display);font-size:clamp(1.3rem,2.5vw,2rem);font-style:italic;line-height:1.5;border:none;padding:0;margin:1.5rem 0}
  .attribution{font-family:var(--font-ui);font-size:0.78rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--mid-grey)}
  @media(max-width:900px){.hero__inner{grid-template-columns:1fr}.hero__image{order:-1}.hero__image img{height:380px}.hero__image::before{display:none}.two-col{grid-template-columns:1fr}.credits-grid{grid-template-columns:1fr 1fr}}
  @media(max-width:600px){.credits-grid{grid-template-columns:1fr}}
</style>

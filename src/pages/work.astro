
---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Previous Work" description="Danièle Lydon's credits span House of the Dragon, Harry Potter and the Cursed Child, Rogue One: A Star Wars Story, and major West End productions.">
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow">Credits</p>
      <h1>Previous Work</h1>
      <div class="gold-rule"></div>
      <p class="hero-sub">A career spanning the West End, Broadway, Hollywood and major international television productions.</p>
    </div>
  </section>
  <section class="section">
    <div class="container">
      <p class="eyebrow">Film, Stage & Television</p>
      <div class="gold-rule"></div>
      <div class="credits-section">
        <div class="credit-feature">
          <div><span class="tag">Television · Lead Voice Coach</span></div>
          <h2>House of the Dragon</h2>
          <p>Lead Voice Coach on HBO's acclaimed series set in the world of Game of Thrones.</p>
        </div>
        <div class="credit-feature">
          <div><span class="tag">West End & International · Resident Dialect Coach</span></div>
          <h2>Harry Potter & The Cursed Child</h2>
          <p>Resident Dialect Coach on the West End production at the Palace Theatre, London. Responsible for adapting Parseltongue from the films to the stage. Helped establish and maintain dialects across the Broadway, Melbourne, San Francisco and Toronto productions, working with over 70 actors.</p>
        </div>
        <div class="credits-list-section">
          <h3>Film</h3>
          <ul class="credits-list">
            <li><span class="credit-title">Rogue One: A Star Wars Story</span><span class="credit-detail">Language creation & dialect</span></li>
            <li><span class="credit-title">Death on the Nile</span><span class="credit-detail">Dialect Coach · Dir. Kenneth Branagh</span></li>
            <li><span class="credit-title">Where is Anne Frank?</span><span class="credit-detail">Dialect · Dir. Ari Folman (Animation)</span></li>
            <li><span class="credit-title">I, Robot (Netflix Animation Series)</span><span class="credit-detail">Accent development</span></li>
            <li><span class="credit-title">Shipbuilders</span><span class="credit-detail">Language creation · German futuristic film</span></li>
          </ul>
        </div>
        <div class="credits-list-section">
          <h3>West End & Theatre</h3>
          <ul class="credits-list">
            <li><span class="credit-title">School of Rock</span><span class="credit-detail">Dialect Residency · Andrew Lloyd Webber</span></li>
            <li><span class="credit-title">Billy Elliott</span><span class="credit-detail">Dialect Residency · West End & National Tour · Dir. Stephen Daldry</span></li>
            <li><span class="credit-title">The King & I</span><span class="credit-detail">West End · With Ken Watanabe</span></li>
            <li><span class="credit-title">You and I</span><span class="credit-detail">Hampstead Theatre · With Maisie Williams</span></li>
          </ul>
        </div>
        <div class="credits-list-section">
          <h3>Television</h3>
          <ul class="credits-list">
            <li><span class="credit-title">Baptiste</span></li>
            <li><span class="credit-title">Lethal White</span></li>
            <li><span class="credit-title">Poldark (Series 2)</span></li>
            <li><span class="credit-title">Sky Arts Urban Myths (Series 2 & 3)</span></li>
            <li><span class="credit-title">Dark Angel</span></li>
            <li><span class="credit-title">An Inspector Calls</span></li>
            <li><span class="credit-title">George Gently (Series 8)</span></li>
            <li><span class="credit-title">The Paradise</span></li>
            <li><span class="credit-title">Vera (Series 4)</span></li>
          </ul>
        </div>
      </div>
    </div>
  </section>
  <section class="section section--dark">
    <div class="container--narrow" style="text-align:center">
      <p class="eyebrow" style="color:var(--gold)">Press</p>
      <div class="gold-rule" style="margin:1.5rem auto;"></div>
      <blockquote style="font-family:var(--font-display);font-size:clamp(1.1rem,2vw,1.6rem);font-style:italic;color:var(--warm-white);line-height:1.6;">"The old-fashioned north-east accents are pretty much note-perfect; the accents here give everything a surprising freshness."</blockquote>
      <p style="font-family:var(--font-ui);font-size:0.78rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--gold);margin-top:2rem;">Time Out</p>
    </div>
  </section>
</Layout>
<style>
  .hero-sub{font-size:1.1rem;color:#555;max-width:600px;margin-top:1.5rem}
  .credits-section{margin-top:3rem;display:flex;flex-direction:column;gap:4rem}
  .credit-feature{border-left:3px solid var(--gold);padding-left:2rem}
  .credit-feature h2{font-size:clamp(1.8rem,3vw,2.5rem);margin:0.5rem 0 1rem}
  .credit-feature p{font-size:1.05rem;color:#555;max-width:680px;line-height:1.8}
  .tag{font-family:var(--font-ui);font-size:0.7rem;font-weight:500;letter-spacing:0.12em;text-transform:uppercase;color:var(--gold)}
  .credits-list-section h3{font-family:var(--font-display);font-size:1.4rem;font-weight:600;margin-bottom:1.5rem;padding-bottom:0.75rem;border-bottom:1px solid var(--light-grey)}
  .credits-list{list-style:none;display:flex;flex-direction:column}
  .credits-list li{display:flex;justify-content:space-between;align-items:baseline;padding:0.85rem 0;border-bottom:1px solid var(--light-grey);gap:2rem}
  .credit-title{font-family:var(--font-display);font-size:1.05rem;font-style:italic}
  .credit-detail{font-family:var(--font-ui);font-size:0.78rem;color:var(--mid-grey);text-align:right;flex-shrink:0}
  @media(max-width:600px){.credits-list li{flex-direction:column;gap:0.2rem}.credit-detail{text-align:left}}
</style>
